  "noise": {
    "count": 1000,
    "templates": [
      "群聊噪声 {index}：今天同步普通进展，模块 {shard} 暂无长期规则。",
      "群聊噪声 {index}：午会提醒只确认临时排期，不沉淀为企业记忆。",
