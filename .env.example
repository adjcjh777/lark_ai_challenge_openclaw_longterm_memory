# Feishu Memory Copilot local development environment.
# Copy this file to .env or .env.local and fill secrets locally.
# Never commit real keys or local data directories.

# RightCode remains the LLM provider. Do not use RightCode for embeddings.
LLM_PROVIDER=custom
LLM_MODEL=gpt-5.3-codex-high
LLM_ENDPOINT=https://right.codes/codex/v1
LLM_API_KEY=  # Required: Your RightCode API key

# Local embedding provider for Cognee/LiteLLM.
# Default: Qwen3-Embedding 0.6B via Ollama, selected for 16GB Mac mini and Windows reproducibility.
EMBEDDING_MODEL=ollama/qwen3-embedding:0.6b-fp16
EMBEDDING_ENDPOINT=http://localhost:11434
EMBEDDING_DIMENSIONS=1024

# Fallback if qwen3-embedding cannot be pulled on a local or Windows machine:
# EMBEDDING_MODEL=ollama/bge-m3:567m
# EMBEDDING_DIMENSIONS=1024

# OpenAI API Key (alternative to LLM_API_KEY if using OpenAI provider)
OPENAI_API_KEY=

# Symphony Elixir orchestration (optional).
# Used by WORKFLOW.md when running the external openai/symphony service.
LINEAR_API_KEY=
SYMPHONY_LINEAR_PROJECT_SLUG=
SYMPHONY_WORKSPACE_ROOT=/Users/junhaocheng/.symphony/workspaces/feishu_ai_challenge
SOURCE_REPO_URL=https://github.com/adjcjh777/lark_ai_challenge_openclaw_longterm_memory.git
CODEX_BIN=codex
