# Example reverse proxy for the read-only LLM Wiki / Graph admin.
# Replace `admin.example.com` and certificate paths before use.

server {
    listen 80;
    server_name admin.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name admin.example.com;

    ssl_certificate /etc/letsencrypt/live/admin.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/admin.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 1m;

    location = /healthz {
        proxy_pass http://127.0.0.1:8765/healthz;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
        # Optional enterprise SSO pattern:
        # - Put oauth2-proxy, Feishu SSO, or another IdP in front of this location.
        # - Keep the Python admin backend bound to 127.0.0.1.
        # - Set FEISHU_MEMORY_COPILOT_ADMIN_SSO_ENABLED=1 and configure
        #   FEISHU_MEMORY_COPILOT_ADMIN_SSO_ADMIN_USERS /
        #   FEISHU_MEMORY_COPILOT_ADMIN_SSO_ALLOWED_DOMAINS.
        #
        # Example with an auth_request endpoint that returns identity headers:
        # auth_request /oauth2/auth;
        # auth_request_set $sso_user $upstream_http_x_auth_request_user;
        # auth_request_set $sso_email $upstream_http_x_auth_request_email;
        # proxy_set_header X-Forwarded-User $sso_user;
        # proxy_set_header X-Forwarded-Email $sso_email;

        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
