# Example environment for deploy/copilot-admin.service.example.
# Copy to /etc/feishu-memory-copilot/admin.env and replace placeholders locally.
# Do not commit the real admin.env file, bearer tokens, IdP secrets, or production DB credentials.

# SQLite staging storage. Production PostgreSQL / PITR is not validated by this bundle.
MEMORY_DB_PATH=/opt/feishu_ai_challenge/data/memory.sqlite

# Keep the Python backend on loopback when using Nginx / SSO reverse proxy.
FEISHU_MEMORY_COPILOT_ADMIN_HOST=127.0.0.1
FEISHU_MEMORY_COPILOT_ADMIN_PORT=8765

# Use distinct random values. Example generation:
#   openssl rand -hex 24
FEISHU_MEMORY_COPILOT_ADMIN_TOKEN=__CHANGE_ME_ADMIN_TOKEN__
FEISHU_MEMORY_COPILOT_ADMIN_VIEWER_TOKEN=__CHANGE_ME_VIEWER_TOKEN__

# Optional reverse-proxy SSO header gate.
# This verifies staging header auth only; it is not real enterprise IdP production validation.
FEISHU_MEMORY_COPILOT_ADMIN_SSO_ENABLED=0
FEISHU_MEMORY_COPILOT_ADMIN_SSO_USER_HEADER=X-Forwarded-User
FEISHU_MEMORY_COPILOT_ADMIN_SSO_EMAIL_HEADER=X-Forwarded-Email
FEISHU_MEMORY_COPILOT_ADMIN_SSO_ADMIN_USERS=admin@example.com
FEISHU_MEMORY_COPILOT_ADMIN_SSO_ALLOWED_DOMAINS=example.com
