{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "feishu-memory-copilot-tools",
  "version": "2026-04-27",
  "openclaw_version": "2026.4.24",
  "description": "OpenClaw tool contract for the Feishu Memory Copilot MVP.",
  "tools": [
    {
      "name": "memory.search",
      "description": "Search active curated memory for a scope and return evidence-backed top-k results.",
      "input_schema": {
        "type": "object",
        "required": ["query", "scope"],
        "additionalProperties": false,
        "properties": {
          "query": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "top_k": {"type": "integer", "minimum": 1, "maximum": 10, "default": 3},
          "filters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["decision", "deadline", "owner", "workflow", "risk", "document", "preference"]
              },
              "layer": {"type": "string", "enum": ["L1", "L2", "L3"]},
              "status": {
                "type": "string",
                "enum": ["candidate", "active", "superseded", "rejected", "stale", "archived"],
                "default": "active"
              }
            }
          },
          "current_context": {"type": "object", "additionalProperties": true}
        }
      },
      "output_schema": {"$ref": "#/$defs/search_output"}
    },
    {
      "name": "memory.create_candidate",
      "description": "Create an evidence-backed memory candidate from an explicit note, Feishu message, document, or benchmark fixture.",
      "input_schema": {
        "type": "object",
        "required": ["text", "scope", "source"],
        "additionalProperties": false,
        "properties": {
          "text": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "source": {"$ref": "#/$defs/source"},
          "current_context": {"type": "object", "additionalProperties": true},
          "auto_confirm": {"type": "boolean", "default": false}
        }
      }
    },
    {
      "name": "memory.confirm",
      "description": "Confirm a candidate as active memory, superseding older active versions when needed.",
      "input_schema": {
        "type": "object",
        "required": ["candidate_id", "scope", "actor_id"],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "actor_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string"}
        }
      }
    },
    {
      "name": "memory.reject",
      "description": "Reject a candidate while keeping an audit record outside default recall.",
      "input_schema": {
        "type": "object",
        "required": ["candidate_id", "scope", "actor_id"],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "actor_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string"}
        }
      }
    },
    {
      "name": "memory.explain_versions",
      "description": "Explain a memory version chain, superseded values, and source evidence.",
      "input_schema": {
        "type": "object",
        "required": ["memory_id", "scope"],
        "additionalProperties": false,
        "properties": {
          "memory_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "include_archived": {"type": "boolean", "default": false}
        }
      }
    },
    {
      "name": "memory.prefetch",
      "description": "Prefetch a compact context pack before an OpenClaw agent task.",
      "input_schema": {
        "type": "object",
        "required": ["task", "scope", "current_context"],
        "additionalProperties": false,
        "properties": {
          "task": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "pattern": "^[^:]+:.+$"},
          "current_context": {"type": "object", "minProperties": 1, "additionalProperties": true},
          "top_k": {"type": "integer", "minimum": 1, "maximum": 10, "default": 5}
        }
      }
    }
  ],
  "error_schema": {
    "type": "object",
    "required": ["ok", "error"],
    "additionalProperties": false,
    "properties": {
      "ok": {"const": false},
      "error": {
        "type": "object",
        "required": ["code", "message", "retryable", "details"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "scope_required",
              "permission_denied",
              "memory_not_found",
              "candidate_not_confirmable",
              "validation_error",
              "sensitive_content_blocked",
              "internal_error"
            ]
          },
          "message": {"type": "string"},
          "retryable": {"type": "boolean"},
          "details": {"type": "object", "additionalProperties": true}
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["source_type", "source_id", "actor_id", "created_at", "quote"],
      "additionalProperties": false,
      "properties": {
        "source_type": {"type": "string", "minLength": 1},
        "source_id": {"type": "string", "minLength": 1},
        "actor_id": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "minLength": 1},
        "quote": {"type": "string", "minLength": 1},
        "source_chat_id": {"type": "string"},
        "source_doc_id": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "required": ["source_type", "source_id", "quote"],
      "additionalProperties": false,
      "properties": {
        "source_type": {"type": "string", "minLength": 1},
        "source_id": {"type": ["string", "null"]},
        "quote": {"type": ["string", "null"]},
        "source_url": {"type": "string"},
        "source_chat_id": {"type": "string"},
        "source_doc_id": {"type": "string"},
        "document_token": {"type": "string"},
        "document_title": {"type": "string"}
      }
    },
    "memory_result": {
      "type": "object",
      "required": ["memory_id", "type", "subject", "current_value", "status", "layer", "version", "score", "rank", "evidence"],
      "additionalProperties": false,
      "properties": {
        "memory_id": {"type": "string", "minLength": 1},
        "type": {"type": "string", "enum": ["decision", "deadline", "owner", "workflow", "risk", "document", "preference"]},
        "subject": {"type": "string", "minLength": 1},
        "current_value": {"type": "string"},
        "status": {"type": "string", "enum": ["active"]},
        "layer": {"type": "string", "enum": ["L1", "L2", "L3"]},
        "version": {"type": ["integer", "null"]},
        "score": {"type": "number"},
        "rank": {"type": "integer", "minimum": 1},
        "evidence": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence"}
        },
        "matched_via": {
          "type": "array",
          "items": {"type": "string"}
        },
        "why_ranked": {"type": "object", "additionalProperties": true}
      }
    },
    "retrieval_trace_step": {
      "type": "object",
      "required": ["layer", "backend", "query", "requested_top_k", "returned_count", "elapsed_ms", "hit_memory_ids"],
      "additionalProperties": false,
      "properties": {
        "layer": {"type": "string"},
        "backend": {"type": "string"},
        "query": {"type": "string"},
        "requested_top_k": {"type": "integer"},
        "returned_count": {"type": "integer"},
        "elapsed_ms": {"type": "number"},
        "hit_memory_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "note": {"type": "string"},
        "layer_source": {"type": "string"},
        "selection_reason": {"type": "string"},
        "dropped_count": {"type": "integer"},
        "stage": {"type": "string"}
      }
    },
    "search_output": {
      "type": "object",
      "required": ["ok", "query", "scope", "top_k", "results", "trace"],
      "additionalProperties": false,
      "properties": {
        "ok": {"const": true},
        "query": {"type": "string"},
        "scope": {"type": "string"},
        "top_k": {"type": "integer"},
        "results": {
          "type": "array",
          "items": {"$ref": "#/$defs/memory_result"}
        },
        "trace": {
          "type": "object",
          "required": ["strategy", "query", "scope", "requested_top_k", "returned_count", "backend", "layers", "stages", "steps", "final_reason", "fallback_used", "cognee_available"],
          "additionalProperties": false,
          "properties": {
            "strategy": {"type": "string"},
            "query": {"type": "string"},
            "scope": {"type": "string"},
            "requested_top_k": {"type": "integer"},
            "returned_count": {"type": "integer"},
            "backend": {"type": "string"},
            "layers": {
              "type": "array",
              "items": {"type": "string", "enum": ["L1", "L2", "L3"]}
            },
            "stages": {
              "type": "array",
              "items": {"type": "string"}
            },
            "steps": {
              "type": "array",
              "items": {"$ref": "#/$defs/retrieval_trace_step"}
            },
            "final_reason": {"type": "string"},
            "fallback_used": {"type": "boolean"},
            "cognee_available": {"type": ["boolean", "null"]}
          }
        }
      }
    }
  }
}
