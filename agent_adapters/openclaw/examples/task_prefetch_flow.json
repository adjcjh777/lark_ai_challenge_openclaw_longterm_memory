{
  "name": "task_prefetch_flow",
  "description": "Prefetch active memory before generating a deployment checklist.",
  "execution_mode": "copyable_openclaw_tool_call",
  "demo_fallback": "python3 scripts/demo_seed.py --json-output reports/demo_replay.json",
  "steps": [
    {
      "tool": "memory.prefetch",
      "arguments": {
        "task": "deployment_checklist",
        "scope": "project:feishu_ai_challenge",
        "current_context": {
          "session_id": "openclaw-demo-session",
          "task_id": "demo-prefetch-001",
          "scope": "project:feishu_ai_challenge",
          "intent": "generate today's deployment checklist",
          "thread_topic": "production deployment",
          "allowed_scopes": ["project:feishu_ai_challenge"],
          "metadata": {
            "current_message": "Help me produce the deployment checklist for today."
          }
        },
        "top_k": 5
      }
    }
  ],
  "expected_output": {
    "ok": true,
    "tool": "memory.prefetch",
    "context_pack_contains": ["relevant_memories", "evidence", "risks", "deadlines", "trace_summary"],
    "state_mutation": "none",
    "raw_events_included": false
  },
  "benchmark_evidence": "docs/benchmark-report.md#样例证据"
}
