{
  "name": "historical_decision_search",
  "description": "Search the active production deployment decision before answering a user.",
  "execution_mode": "copyable_openclaw_tool_call",
  "demo_fallback": "python3 scripts/demo_seed.py --json-output reports/demo_replay.json",
  "steps": [
    {
      "tool": "fmc_memory_search",
      "arguments": {
        "query": "production deployment region",
        "scope": "project:feishu_ai_challenge",
        "top_k": 3,
        "filters": {
          "status": "active",
          "type": "decision"
        },
        "current_context": {
          "session_id": "openclaw-demo-session",
          "scope": "project:feishu_ai_challenge",
          "intent": "answer a historical decision question",
          "thread_topic": "production deployment",
          "allowed_scopes": ["project:feishu_ai_challenge"],
          "permission": {
            "request_id": "req_demo_search_allow",
            "trace_id": "trace_demo_search_allow",
            "actor": {
              "user_id": "user_demo_reviewer",
              "tenant_id": "tenant:demo",
              "organization_id": "org:demo",
              "roles": ["member", "reviewer"]
            },
            "source_context": {
              "entrypoint": "openclaw",
              "workspace_id": "project:feishu_ai_challenge"
            },
            "requested_action": "fmc_memory_search",
            "requested_visibility": "team",
            "timestamp": "2026-05-07T00:00:00+08:00"
          }
        }
      }
    }
  ],
  "expected_output": {
    "ok": true,
    "results_status": "active",
    "must_include": ["layer", "evidence", "matched_via", "why_ranked", "trace.steps", "bridge.request_id", "bridge.trace_id", "bridge.permission_decision"],
    "bridge_permission_decision": "allow"
  },
  "benchmark_evidence": "docs/benchmark-report.md#样例证据"
}
