{
  "name": "conflict_update_flow",
  "description": "Create and confirm a candidate that supersedes an older deployment rule.",
  "execution_mode": "schema_demo_with_runtime_ids",
  "runtime_note": "The candidate_id returned by step 1 must be copied into step 2. The memory_id returned after confirmation must be copied into step 3.",
  "demo_fallback": "python3 scripts/demo_seed.py --json-output reports/demo_replay.json",
  "steps": [
    {
      "tool": "memory.create_candidate",
      "arguments": {
        "text": "Correction: production deployment region is ap-shanghai from now on.",
        "scope": "project:feishu_ai_challenge",
        "source": {
          "source_type": "feishu_message",
          "source_id": "msg_demo_conflict_001",
          "actor_id": "user_demo_owner",
          "created_at": "2026-04-26T10:00:00+08:00",
          "quote": "Correction: production deployment region is ap-shanghai from now on.",
          "source_chat_id": "chat_demo_project"
        },
        "auto_confirm": false
      }
    },
    {
      "tool": "memory.confirm",
      "arguments": {
        "candidate_id": "<candidate_id_from_step_1>",
        "scope": "project:feishu_ai_challenge",
        "actor_id": "user_demo_owner",
        "reason": "Confirmed in project chat"
      }
    },
    {
      "tool": "memory.explain_versions",
      "arguments": {
        "memory_id": "<memory_id_from_step_2>",
        "scope": "project:feishu_ai_challenge",
        "include_archived": false
      }
    }
  ],
  "expected_output": {
    "ok": true,
    "version_chain_contains": ["active", "superseded"],
    "default_search_should_not_return": ["cn-shanghai"]
  },
  "benchmark_evidence": "docs/benchmark-report.md#样例证据"
}
